---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout title={`${post.data.title} — Oscar Villarreal`} description={post.data.description}>
  <style>
    .post-header {
      padding-top: 5rem;
      padding-bottom: 2.5rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 2.5rem;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.85rem;
      color: var(--muted);
      text-decoration: none;
      margin-bottom: 2rem;
      transition: color 0.15s;
    }
    .back-link:hover { color: var(--fg); }

    .post-meta {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .post-date {
      font-size: 0.85rem;
      color: var(--muted);
    }

    .post-tags { display: flex; gap: 0.35rem; flex-wrap: wrap; }

    h1 {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.2;
      margin-bottom: 0.75rem;
    }

    .post-desc {
      font-size: 1.05rem;
      color: var(--muted);
      line-height: 1.7;
    }

    /* Prose */
    .prose {
      font-size: 1rem;
      line-height: 1.8;
      color: var(--prose-color);
    }

    .prose :global(h2) {
      font-size: 1.375rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin: 2.5rem 0 1rem;
      color: var(--fg);
    }

    .prose :global(h3) {
      font-size: 1.125rem;
      font-weight: 600;
      margin: 2rem 0 0.75rem;
      color: var(--fg);
    }

    .prose :global(p) { margin-bottom: 1.25rem; }

    .prose :global(a) {
      color: var(--accent);
      text-decoration: underline;
      text-decoration-color: rgba(77,166,255,0.4);
      text-underline-offset: 3px;
    }
    .prose :global(a:hover) { text-decoration-color: var(--accent); }

    .prose :global(ul),
    .prose :global(ol) {
      padding-left: 1.5rem;
      margin-bottom: 1.25rem;
    }
    .prose :global(li) { margin-bottom: 0.4rem; }

    .prose :global(code) {
      font-family: "SF Mono", "Fira Code", "Cascadia Code", monospace;
      font-size: 0.875em;
      background: var(--code-bg);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0.15em 0.4em;
      color: var(--code-color);
    }

    .prose :global(pre) {
      background: var(--pre-bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.25rem 1.5rem;
      overflow-x: auto;
      margin-bottom: 1.5rem;
      font-size: 0.875rem;
      line-height: 1.65;
    }
    .prose :global(pre code) {
      background: none;
      border: none;
      padding: 0;
      font-size: inherit;
    }

    .prose :global(blockquote) {
      border-left: 3px solid var(--accent);
      padding-left: 1.25rem;
      margin: 1.5rem 0;
      color: var(--muted);
      font-style: italic;
    }

    .prose :global(hr) {
      border: none;
      border-top: 1px solid var(--border);
      margin: 2.5rem 0;
    }

    .prose :global(img) {
      max-width: 100%;
      border-radius: 8px;
      border: 1px solid var(--border);
      margin: 1.5rem 0;
    }
  </style>

  <div class="post-header">
    <a class="back-link" href="/blog">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      <span data-lang="en">All posts</span>
      <span data-lang="es">Todas las publicaciones</span>
    </a>

    <div class="post-meta">
      <span class="post-date">{formatDate(post.data.pubDate)}</span>
      {post.data.tags && (
        <div class="post-tags">
          {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )}
    </div>

    <h1 transition:name={`post-title-${post.slug}`}>{post.data.title}</h1>
    <p class="post-desc">{post.data.description}</p>
  </div>

  <div class="prose">
    <Content />
  </div>
</Layout>
