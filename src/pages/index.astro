---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <style>
    section { padding: 4rem 0; border-bottom: 1px solid var(--border); }
    section:last-child { border-bottom: none; }
    section:not(#hero) { max-width: 720px; margin-left: auto; margin-right: auto; }

    /* Hero */
    @keyframes hero-gradient {
      0%   { background-position: 0% 50%; }
      50%  { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    #hero {
      padding: 0;
      border-bottom: none;
      background: linear-gradient(-45deg, var(--hero-c1), var(--hero-c2), var(--hero-c3), var(--hero-c4));
      background-size: 400% 400%;
      animation: hero-gradient 12s ease infinite;
      border-radius: 0 0 24px 24px;
      /* full-width breakout */
      position: relative;
      left: 50%;
      transform: translateX(-50%);
      width: 100vw;
    }

    .hero-inner {
      max-width: 720px;
      margin: auto;
      padding: 7.5rem 0rem 7.5rem;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 2.5rem;
    }

    .hero-text { flex: 1; min-width: 0; }

    .eyebrow {
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1rem;
    }

    h1 {
      font-size: clamp(1.75rem, 4vw, 2.75rem);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.15;
      margin-bottom: 1.25rem;
    }

    .hero-desc {
      font-size: 1.05rem;
      color: var(--muted);
      margin-bottom: 2rem;
      line-height: 1.7;
    }

    .hero-links { display: flex; gap: 0.6rem; flex-wrap: wrap; }

    .hero-photo {
      flex-shrink: 0;
      width: 180px;
      height: 180px;
      border-radius: 50%;
      overflow: hidden;
      border: 2px solid var(--border);
      box-shadow: 0 0 0 4px rgba(77,166,255,0.08);
    }
    .hero-photo img {
      width: 100%; height: 100%;
      object-fit: cover;
      object-position: center top;
      display: block;
    }

    @media (max-width: 560px) {
      .hero-inner { flex-direction: column; align-items: flex-start; padding-left: 1.5rem; padding-right: 1.5rem; }
      .hero-photo { width: 100px; height: 100px; }
    }

    /* Section headings */
    h2 {
      font-size: 1.375rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-bottom: 2rem;
    }

    /* Projects */
    .projects { display: flex; flex-direction: column; gap: 1.25rem; }

    .project-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.5rem;
      transition: border-color 0.15s;
    }
    .project-card:hover { border-color: var(--border-hover); }

    .project-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 0.6rem;
    }

    .project-name {
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    a.project-name {
      color: inherit;
      text-decoration: none;
    }
    a.project-name:hover { color: var(--accent); }
    .project-icon {
      width: 20px;
      height: 20px;
      object-fit: contain;
      flex-shrink: 0;
      display: block;
    }

    .project-label {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      padding: 0.2rem 0.55rem;
      border-radius: 4px;
      background: var(--accent-dim);
      color: var(--accent);
      white-space: nowrap;
    }

    .project-desc {
      font-size: 0.925rem;
      color: var(--muted);
      margin-bottom: 1rem;
      line-height: 1.65;
    }

    .tag-list { display: flex; flex-wrap: wrap; gap: 0.4rem; }

    .tag {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
    }
    .tag i { font-size: 0.85rem; line-height: 1; }
    .tag img { width: 14px; height: 14px; flex-shrink: 0; }

    /* Stack */
    .stack-category { margin-bottom: 1.75rem; }
    .stack-category:last-child { margin-bottom: 0; }

    .stack-category-label {
      font-size: 0.72rem;
      font-weight: 500;
      letter-spacing: 0.09em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.65rem;
    }

    .stack-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(88px, 1fr));
      gap: 0.65rem;
    }

    .stack-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0.85rem 0.5rem 0.7rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.45rem;
      min-height: 72px;
      transition: border-color 0.15s, background 0.15s;
    }
    .stack-item:hover { border-color: var(--border-hover); background: var(--surface-hover); }
    .stack-item i { font-size: 1.875rem; line-height: 1; }
    .stack-item img { width: 1.875rem; height: 1.875rem; object-fit: contain; }
    .stack-item span { font-size: 0.7rem; color: var(--muted); text-align: center; line-height: 1.3; }

    /* Languages */
    .lang-list { display: flex; flex-direction: column; gap: 0.85rem; }

    .lang-item {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .lang-name {
      font-size: 0.925rem;
      font-weight: 500;
      width: 80px;
      flex-shrink: 0;
    }

    .lang-level {
      font-size: 0.78rem;
      color: var(--muted);
      width: 180px;
      flex-shrink: 1;
      min-width: 0;
    }

    .lang-dots {
      display: flex;
      gap: 0.35rem;
    }

    .lang-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--border);
    }
    .lang-dot.filled { background: var(--accent); }

    /* Education */
    .edu-card {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.5rem;
    }

    .edu-logo {
      width: 48px;
      height: 48px;
      object-fit: contain;
      flex-shrink: 0;
      border-radius: 8px;
    }

    .edu-degree {
      font-size: 0.975rem;
      font-weight: 600;
      margin-bottom: 0.2rem;
    }

    .edu-school {
      font-size: 0.875rem;
      color: var(--muted);
      margin-bottom: 0.2rem;
    }

    .edu-period {
      font-size: 0.78rem;
      color: var(--muted);
    }

    @media (max-width: 480px) {
      .lang-item { flex-wrap: wrap; row-gap: 0.35rem; }
      .lang-name { width: 100%; }
      .lang-level { width: auto; }
    }

    /* About */
    .about-text { font-size: 1rem; color: var(--muted); line-height: 1.75; }
    .about-text p + p { margin-top: 1rem; }

  </style>

