  <script>
    import { animate, inView } from "motion";

    function initScrollReveal() {
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

      const enter = { opacity: 1, y: 0 };
      const opts = { duration: 0.5, easing: "ease" };

      function setup(el, delay) {
        el.style.opacity = "0";
        el.style.transform = "translateY(20px)";
        inView(el, function() {
          animate(el, enter, { duration: opts.duration, easing: opts.easing, delay: delay || 0 });
        });
      }

      document.querySelectorAll("section:not(#hero) h2").forEach(function(el) {
        setup(el);
      });

      document.querySelectorAll(".project-card").forEach(function(el, i) {
        setup(el, i * 0.07);
      });

      document.querySelectorAll(".stack-category").forEach(function(el) {
        setup(el);
      });

      document.querySelectorAll(".lang-item").forEach(function(el, i) {
        setup(el, i * 0.06);
      });

      document.querySelectorAll(".edu-card").forEach(function(el) {
        setup(el);
      });

      document.querySelectorAll(".about-text").forEach(function(el) {
        setup(el);
      });
    }

    document.addEventListener("astro:page-load", initScrollReveal);
  </script>
</Layout>
